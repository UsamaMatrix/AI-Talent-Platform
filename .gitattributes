# Force LF line endings for all text files
* text=auto eol=lf

# Explicitly LF
*.py    text eol=lf
*.ts    text eol=lf
*.tsx   text eol=lf
*.js    text eol=lf
*.jsx   text eol=lf
*.json  text eol=lf
*.yml   text eol=lf
*.yaml  text eol=lf
*.toml  text eol=lf
*.md    text eol=lf
*.css   text eol=lf
*.sh    text eol=lf

# Windows scripts keep CRLF
*.bat   text eol=crlf
*.cmd   text eol=crlf

# Binaries
*.png   binary
*.jpg   binary
*.ico   binary
*.woff  binary
*.woff2 binary
