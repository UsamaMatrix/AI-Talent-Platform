# ── Database ──────────────────────────────────────────────────────────────────
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=talent_platform
POSTGRES_USER=talent_user
POSTGRES_PASSWORD=change_me

DATABASE_URL=postgresql+asyncpg://talent_user:change_me@localhost:5432/talent_platform

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── MinIO / S3 ────────────────────────────────────────────────────────────────
STORAGE_BACKEND=minio
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=change_me
MINIO_BUCKET=talent-platform
AWS_S3_BUCKET=talent-platform
AWS_REGION=us-east-1

# ── API ───────────────────────────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000
API_DEBUG=false
API_SECRET_KEY=change_me_32_chars_minimum_secret
ALLOWED_ORIGINS=http://localhost:3000
LOG_LEVEL=INFO
LOG_FORMAT=json

# ── Auth ──────────────────────────────────────────────────────────────────────
JWT_SECRET_KEY=change_me_jwt_secret
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# ── LLM Gateway ───────────────────────────────────────────────────────────────
LLM_DEFAULT_PROVIDER=openai
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...
GOOGLE_API_KEY=AIza...

# ── Celery ────────────────────────────────────────────────────────────────────
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# ── Observability ─────────────────────────────────────────────────────────────
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
OTEL_SERVICE_NAME=talent-platform-api

# ── Frontend ──────────────────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:8000
